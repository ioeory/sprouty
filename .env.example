# ---- Sprouty (萌记) runtime environment ----
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Internal identifiers keep the `sprouts*` prefix as the project's code name.

# Database Config
DB_HOST=db
DB_USER=sprouts
DB_PASSWORD=change_me_please
DB_NAME=sprouts_db
DB_PORT=5432

# Server Config
PORT=8080
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string

# Bot Config (Phase 4)
# 从 @BotFather 获取的 token（不要带引号）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 机器人用户名（不含 @），前端绑定页面会生成深链接 https://t.me/<username>?start=...
TELEGRAM_BOT_USERNAME=your_bot_username
# 可选：如果宿主机访问 api.telegram.org 被墙，设置代理
# 例如 http://host.docker.internal:7890 或 socks5://host.docker.internal:7890
BOT_PROXY=
